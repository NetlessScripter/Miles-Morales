local lensFlareTemplate = LensFlareTemplate

local zOffsetValue = Instance.new("NumberValue")
zOffsetValue.Name = "ZOffset"
zOffsetValue.Value = -10
zOffsetValue.Parent = script
local zOffset = zOffsetValue.Value

-- ===== Core logic =====

-- Keeps the "ignore my own character" raycast tag in sync. Only needs to run
-- once per frame since it doesn't depend on which flare is currently being processed.
local function updatePassthroughTag(cameraPosition)
	local character = LocalPlayer.Character
	if not character then
		return
	end
	if LocalPlayer:DistanceFromCharacter(cameraPosition) <= CHARACTER_PASSTHROUGH_DISTANCE then
		CollectionService:AddTag(character, PASSTHROUGH_TAG)
	else
		CollectionService:RemoveTag(character, PASSTHROUGH_TAG)
	end
end

-- Returns (isVisible, screenPosition). screenPosition is nil when the source
-- is off-screen / behind the camera, in which case isVisible is also false.
local function testFlareVisibility(cameraPosition, worldPosition, flareSource, passthroughList)
	local viewportPoint, isOnScreen = Camera:WorldToViewportPoint(worldPosition)
	if not isOnScreen then
		return false, nil
	end

	-- WorldToViewportPoint returns a Vector3 (screen X, screen Y, depth). Only
	-- the screen-space X/Y matter from here on, so drop the depth component.
	local screenPosition = Vector2.new(viewportPoint.X, viewportPoint.Y)

	local raycastParams = RaycastParams.new()
	raycastParams.IgnoreWater = true

	local filterList = table.clone(passthroughList)
	table.insert(filterList, flareSource)
	raycastParams.FilterDescendantsInstances = filterList

	local rayDirection = worldPosition - cameraPosition
	local isOccluded = workspace:Raycast(cameraPosition, rayDirection, raycastParams) ~= nil

	return not isOccluded, screenPosition
end

-- Resizes flarePart so it exactly covers the camera viewport at zOffset studs away.
-- Returns the current viewport size.
local function updateFlarePartSize()
	zOffset = zOffsetValue.Value
	local viewportSize = Camera.ViewportSize
	local worldWidth = screenWidthToWorldWidth(viewportSize.X, zOffset)
	local worldHeight = screenHeightToWorldHeight(viewportSize.Y, zOffset)
	flarePart.Size = Vector3.new(worldWidth, worldHeight, 0.001)
	return viewportSize
end

local function hideFlareImages(frame)
	for _, image in ipairs(frame:GetChildren()) do
		if image:IsA("ImageLabel") then
			image.Visible = false
			image.ImageTransparency = 1
		end
	end
end

local function rememberBaseAppearance(image)
	if image:GetAttribute("BaseImageColor3") == nil then
		image:SetAttribute("BaseImageColor3", image.ImageColor3)
	end
	if image:GetAttribute("BaseImageTransparency") == nil then
		image:SetAttribute("BaseImageTransparency", image.ImageTransparency)
	end
end

local function getPseudoAdditiveAppearance(image, targetTransparency)
	rememberBaseAppearance(image)
	local baseColor = image:GetAttribute("BaseImageColor3") or Color3.new(1, 1, 1)
	local alpha = 1 - math.clamp(targetTransparency, 0, 1)
	local bloom = math.clamp(alpha ^ 1.35, 0, 1)
	local whiten = math.clamp(PSEUDO_BLEND_WHITENING + bloom * PSEUDO_BLEND_BOOST, 0, 1)
	local blendedColor = baseColor:Lerp(Color3.new(1, 1, 1), whiten)
	local blendedTransparency = math.clamp(targetTransparency * (1 - bloom * 0.12), 0, 1)
	return blendedColor, blendedTransparency
end

local function updateLensFlares()
	local sunDirection = Lighting:GetSunDirection()
	sunFlarePart.Position = Camera.CFrame.Position + sunDirection * SUN_DISTANCE

	local viewportSize = updateFlarePartSize()
	flarePart.CFrame = Camera.CFrame * CFrame.new(0, 0, zOffset)

	local aspectRatio = viewportSize.X / viewportSize.Y
	local viewportCenter = viewportSize * 0.5
	local cameraPosition = Camera.CFrame.Position

	updatePassthroughTag(cameraPosition)
	local passthroughList = CollectionService:GetTagged(PASSTHROUGH_TAG)

	for _, flareSource in ipairs(CollectionService:GetTagged(FLARE_TAG)) do
		local flareUI = flareSource:FindFirstChild("FlareUI")
		if not flareUI then
			flareUI = lensFlareTemplate:Clone()
			flareUI.Name = "FlareUI"
			flareUI.Parent = flareSource
		end

		local frame = flareUI:FindFirstChild("Frame")
		if not frame then
			continue
		end

		flareUI.Adornee = flarePart
		flareUI.Enabled = true
		flareUI.CanvasSize = viewportSize

		local sourcePosition = flareSource.Position
		local isVisible, screenPosition =
			testFlareVisibility(cameraPosition, sourcePosition, flareSource, passthroughList)

		if not screenPosition then
			hideFlareImages(frame)
			continue
		end

		local screenOffsetFromCenter = viewportCenter - screenPosition

		for _, image in ipairs(frame:GetChildren()) do
			if not image:IsA("ImageLabel") then
				continue
			end

			image.Visible = true

			-- Position this element along the line from screen center through the flare source.
			-- NOTE: falls back to (0, 0) / 0 because the current LensFlareTemplate's ImageLabels
			-- don't have these attributes set yet — every element will sit on top of the flare
			-- source until real Offset/BaseRotation/Transparency values are authored per image.
			local elementOffset = image:GetAttribute("Offset") or Vector2.new(0, 0)
			local elementPosition = screenPosition + screenOffsetFromCenter * 0.05 + screenOffsetFromCenter * elementOffset
			image.Position = UDim2.new(0, elementPosition.X, 0, elementPosition.Y)

			if image:GetAttribute("CanRotate") then
				local baseRotation = image:GetAttribute("BaseRotation") or 0
				local directionFromCenter = elementPosition - screenPosition
				local angle = math.atan2(directionFromCenter.Y, directionFromCenter.X)
				image.Rotation = math.deg(angle) - 90 + baseRotation
			end

			-- Fade out near the edge of the screen and with distance falloff.
			-- Falls back to "no falloff" / "neutral strength" for any flare source
			-- that hasn't had these attributes set (the sun part sets them in code above).
			local edgeDistance = Vector2.new(math.abs(screenOffsetFromCenter.X), math.abs(screenOffsetFromCenter.Y))
			local flareRange = flareSource:GetAttribute("LensFlareRange") or 0
			local flareStrength = flareSource:GetAttribute("LensFlareStrength") or 1
			local baseTransparency = image:GetAttribute("Transparency") or 0
			local distanceFalloff = (flareRange <= 0) and 0 or (cameraPosition - sourcePosition).Magnitude / flareRange

			local targetTransparency
			if isVisible then
				local edgeFade = (edgeDistance / viewportCenter).Magnitude / aspectRatio / flareStrength
				targetTransparency = math.clamp(baseTransparency + edgeFade + distanceFalloff, baseTransparency, 1)
			else
				targetTransparency = 1
			end

			if PSEUDO_ADDITIVE_BLENDING then
				local blendedColor, blendedTransparency = getPseudoAdditiveAppearance(image, targetTransparency)
				image.ImageColor3 = blendedColor
				TweenService:Create(image, FADE_TWEEN_INFO, { ImageTransparency = blendedTransparency }):Play()
			else
				TweenService:Create(image, FADE_TWEEN_INFO, { ImageTransparency = targetTransparency }):Play()
			end
		end
	end
end

RunService:BindToRenderStep("LensFlareIterate", Enum.RenderPriority.Camera.Value + 1, updateLensFlares)
