-- LensFlare.client.lua
-- Renders a screen-space lens flare UI for every instance tagged "LensFlare"
-- (the sun, light sources, etc). Handles occlusion via raycasting, edge-of-screen
-- fade out, and falloff by distance.
--
-- Fully self-contained: this used to require a small "ScreenSpace" ModuleScript
-- as a sibling of this script. That module's math has been inlined below, so
-- it no longer needs to exist as a separate file.
--
-- Must be a LocalScript. Everything here only ever touches the local player's
-- own character, camera, and PlayerGui, so it's already entirely client-side.

local CollectionService = game:GetService("CollectionService")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- ===== Config =====

local FLARE_TAG = "LensFlare"
local PASSTHROUGH_TAG = "LensFlarePassthrough"
local FADE_TWEEN_INFO = TweenInfo.new(0.025, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
local CHARACTER_PASSTHROUGH_DISTANCE = 2 -- studs; ignore own character in raycasts when camera is this close to it
local SUN_DISTANCE = 12000 -- studs; how far out to place the virtual sun flare source
-- Roblox UI does not expose a true GL_ONE, GL_ONE blend mode, so this script
-- uses a best-effort additive-style approximation by biasing bright flares
-- toward white and giving them a small extra bloom pass.
local PSEUDO_ADDITIVE_BLENDING = true
local PSEUDO_BLEND_WHITENING = 0.42
local PSEUDO_BLEND_BOOST = 0.22

-- ===== Screen-space helpers (inlined "ScreenSpace" module) =====
-- Converts a size in screen pixels into a size in studs at a given distance
-- from the camera, based on the camera's vertical field of view.
--
-- getViewSizeX/Y always report the LARGER raw viewport dimension as "X" and
-- the smaller as "Y", regardless of device orientation, so the math below
-- behaves like landscape even on a portrait screen. This is intentional and
-- matches the original ScreenSpace module's behavior.
-- Note the negated results: these are meant to be used with a NEGATIVE
-- `distance` (e.g. a negative ZOffset), since a negative local Z is what
-- puts the flare part in front of the camera. A negative distance combined
-- with the negation here yields a positive, usable size.

local function getViewSizeX()
	local viewportSize = Camera.ViewportSize
	local rawX, rawY = viewportSize.X, viewportSize.Y
	if rawX == 0 then
		return 1024
	elseif rawY < rawX then
		return rawX
	else
		return rawY
	end
end

local function getViewSizeY()
	local viewportSize = Camera.ViewportSize
	local rawX, rawY = viewportSize.X, viewportSize.Y
	if rawY == 0 then
		return 768
	elseif rawY < rawX then
		return rawY
	else
		return rawX
	end
end

local function getAspectRatio()
	return getViewSizeX() / getViewSizeY()
end

local function screenWidthToWorldWidth(screenWidth, distance)
	local halfFovRad = math.rad(Camera.FieldOfView) / 2
	local widthFactor = getAspectRatio() * math.tan(halfFovRad)
	return -(screenWidth / getViewSizeX()) * 2 * widthFactor * distance
end

local function screenHeightToWorldHeight(screenHeight, distance)
	local halfFovRad = math.rad(Camera.FieldOfView) / 2
	local heightFactor = math.tan(halfFovRad)
	return -(screenHeight / getViewSizeY()) * 2 * heightFactor * distance
end

